# Postgres connection string (e.g. Neon, Supabase, local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/imax70mm"

# Auth.js secret — generate with `openssl rand -base64 32`
AUTH_SECRET=""

# Google OAuth credentials (Google Cloud Console -> OAuth client)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Canonical URL Auth.js uses for callbacks (e.g. http://localhost:3000 in dev)
AUTH_URL="http://localhost:3000"

# Resend API key for transactional email
RESEND_API_KEY=""

# "From" address for outgoing emails (must be a verified Resend sender/domain)
EMAIL_FROM="IMAX 70mm Tracker <alerts@example.com>"

# AMC official API vendor key (X-AMC-Vendor-Key header)
AMC_VENDOR_KEY=""

# Shared secret required in the Authorization header for the cron poll endpoint
CRON_SECRET=""

# Public base URL of the deployed app, used to build links in emails
APP_URL="http://localhost:3000"
