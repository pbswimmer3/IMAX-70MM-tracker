# Postgres connection string (e.g. Neon, Supabase, local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/imax70mm"

# Auth.js secret — generate with `openssl rand -base64 32`
AUTH_SECRET=""

# Google OAuth credentials (Google Cloud Console -> OAuth client)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Canonical URL Auth.js uses for callbacks (e.g. http://localhost:3000 in dev)
AUTH_URL="http://localhost:3000"

# Gmail SMTP for transactional email (no custom domain needed).
# GMAIL_USER = your full Gmail address.
# GMAIL_APP_PASSWORD = a 16-char Google App Password (requires 2-Step
# Verification: Google Account -> Security -> App passwords). NOT your login
# password. Free Gmail sends up to ~500 recipients/day.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# "From" address for outgoing emails. Gmail forces the address to GMAIL_USER,
# so only the display name matters here. Leave blank to auto-use GMAIL_USER.
EMAIL_FROM="IMAX 70mm Tracker <you@gmail.com>"

# AMC official API vendor key (X-AMC-Vendor-Key header)
AMC_VENDOR_KEY=""

# Shared secret required in the Authorization header for the cron poll
# endpoint, and also for /api/ingest and /api/scrape-config (used by the
# headless-browser scraper in scraper/). Must also be set as a GitHub Actions
# repo secret (CRON_SECRET) for the scheduled scrape workflow to authenticate.
CRON_SECRET=""

# Public base URL of the deployed app, used to build links in emails and by
# the scraper to reach /api/ingest + /api/scrape-config. Must also be set as
# a GitHub Actions repo secret (APP_URL) for the scheduled scrape workflow.
APP_URL="http://localhost:3000"

# Comma-separated emails allowed to add movies at /movies. Leave blank for
# single-user mode (any signed-in user may add). Set this once others can sign in.
ADMIN_EMAILS=""

# Set to true/1/yes to run scraper/scrape.ts locally without posting to
# /api/ingest (logs what it finds instead). Not used in production.
DRY_RUN=""
